generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id             String        @id @default(uuid())
  title          String
  description    String?
  coverImage     String
  rating         Float
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  releaseDate    DateTime
  publisher      String?
  price          Float
  discount       Float? // Discount in percentage or currency
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  specialOfferId String?
  specialOffer   SpecialOffer? @relation(fields: [specialOfferId], references: [id], onDelete: SetNull)

  @@index([title])
}

model Category {
  id    String @id @default(uuid())
  name  String
  image String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  games Game[]
}

model SpecialOffer {
  id          String   @id @default(uuid())
  title       String
  description String
  coverImage  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  games Game[]
}
